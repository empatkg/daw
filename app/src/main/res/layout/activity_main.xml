<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#1E1E1E">

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="2dp"
            android:backgroundTint="#4CAF50"
            android:text="▶"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="2dp"
            android:backgroundTint="#F44336"
            android:text="■"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:background="#444444" />

        <Button
            android:id="@+id/btnAddTrack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:backgroundTint="#2196F3"
            android:text="+ Track"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:backgroundTint="#FF9800"
            android:text="Clear"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <com.daw.TransportView
        android:id="@+id/transportView"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="2dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#2D2D2D"
                android:paddingLeft="8dp"
                android:text="SEQUENCER"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.daw.SequencerView
                android:id="@+id/sequencerView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#2D2D2D"
                android:paddingLeft="8dp"
                android:text="STEP PAD"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.daw.StepPadView
                android:id="@+id/stepPadView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#2D2D2D"
                android:paddingLeft="8dp"
                android:text="PIANO ROLL"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.daw.PianoRollView
                android:id="@+id/pianoRollView"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#2D2D2D"
                android:paddingLeft="8dp"
                android:text="MIXER"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.daw.MixerView
                android:id="@+id/mixerView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#2D2D2D"
                android:paddingLeft="8dp"
                android:text="EFFECTS"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.daw.EffectsRackView
                android:id="@+id/effectsRackView"
                android:layout_width="match_parent"
                android:layout_height="200dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>